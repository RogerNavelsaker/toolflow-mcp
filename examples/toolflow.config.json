{
  "plugins": [
    {
      "name": "flox-bridge",
      "module": "./src/plugins/flox-bridge.ts",
      "enabled": true,
      "config": {
        "command": "flox-mcp"
      }
    },
    {
      "name": "example-http",
      "module": "./src/plugins/example-http.ts",
      "enabled": true,
      "config": {
        "baseUrl": "https://example.com/api"
      }
    },
    {
      "name": "nixos-bridge",
      "module": "./src/plugins/nixos-bridge.ts",
      "enabled": true,
      "config": {
        "command": "mcp-nixos"
      }
    }
  ]
}
